      <guid>https://NonoNoe.github.io/posts/unity%E5%9C%BA%E6%99%AF%E7%83%98%E7%84%99%E4%B8%AA%E4%BA%BA%E6%80%BB%E7%BB%93/</guid>
      <description>&lt;div class=&#34;my-toc&#34;&gt;&#xD;&#xA;  &lt;h1&gt;目录&lt;/h1&gt;&#xD;&#xA;  &lt;nav id=&#34;TableOfContents&#34;&gt;&#xA;  &lt;ul&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#简介&#34;&gt;简介&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#no1-基础概念-认识-unity-中的四种光源&#34;&gt;No.1 基础概念-认识 Unity 中的四种光源&lt;/a&gt;&#xA;      &lt;ul&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#四种光源的大致选择&#34;&gt;四种光源的大致选择&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#光源的参数调整&#34;&gt;光源的参数调整&lt;/a&gt;&lt;/li&gt;&#xA;      &lt;/ul&gt;&#xA;    &lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#no2-基础概念-渲染管线&#34;&gt;No.2 基础概念-渲染管线&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#no3-基础概念-material材质和shader渲染算法&#34;&gt;No.3 基础概念-Material材质和Shader渲染算法&lt;/a&gt;&#xA;      &lt;ul&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#rendering-mode&#34;&gt;Rendering Mode&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#main-maps-部分常用参数&#34;&gt;Main Maps 部分常用参数&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#secondary-maps-次级贴图&#34;&gt;Secondary Maps 次级贴图&lt;/a&gt;&lt;/li&gt;&#xA;      &lt;/ul&gt;&#xA;    &lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#no4-光照探针和反射探针&#34;&gt;No.4 光照探针和反射探针&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#no5-lightmap-光照贴图&#34;&gt;No.5 LightMap 光照贴图&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#no6-插件-bakery-lightmapper&#34;&gt;No.6 插件 Bakery Lightmapper&lt;/a&gt;&lt;/li&gt;&#xA;  &lt;/ul&gt;&#xA;&lt;/nav&gt;&#xD;&#xA;&lt;/div&gt;&#xA;&lt;a href=&#34;#&#34; class=&#34;back-to-top&#34;&gt;↑ 返回顶部&lt;/a&gt;&#xD;&#xA;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;   &#xD;&#xA;  .back-to-top {&#xD;&#xA;    position: fixed;&#xD;&#xA;     &#xD;&#xA;    bottom: 20px;&#xD;&#xA;     &#xD;&#xA;    right: 80px;&#xD;&#xA;     &#xD;&#xA;    background-color: #3c3c3c;&#xD;&#xA;    color: #fff;&#xD;&#xA;    padding: 0.6rem 1rem;&#xD;&#xA;    border-radius: 5px;&#xD;&#xA;    text-decoration: none;&#xD;&#xA;    font-size: 1.2rem;&#xD;&#xA;    display: none;&#xD;&#xA;     &#xD;&#xA;    z-index: 1000;&#xD;&#xA;    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);&#xD;&#xA;    transition: opacity 0.3s ease;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;  .back-to-top:hover {&#xD;&#xA;    background-color: #b4b4b4;&#xD;&#xA;    color: rgb(255, 255, 255);&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;  .back-to-top.show {&#xD;&#xA;    display: block;&#xD;&#xA;  }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&#xD;&#xA;&lt;script&gt;&#xD;&#xA;  &#xD;&#xA;  const btn = document.querySelector(&#39;.back-to-top&#39;);&#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;  window.addEventListener(&#39;scroll&#39;, () =&gt; {&#xD;&#xA;    if (window.scrollY &gt; 200) { &#xD;&#xA;      btn.classList.add(&#39;show&#39;);&#xD;&#xA;    } else {&#xD;&#xA;      btn.classList.remove(&#39;show&#39;);&#xD;&#xA;    }&#xD;&#xA;  });&#xD;&#xA;&lt;/script&gt;&#xA;&lt;h2 id=&#34;简介&#34;&gt;&#xA;  简介&#xA;  &lt;a class=&#34;heading-link&#34; href=&#34;#%e7%ae%80%e4%bb%8b&#34;&gt;&#xA;    &lt;i class=&#34;fa-solid fa-link&#34; aria-hidden=&#34;true&#34; title=&#34;链接到标题&#34;&gt;&lt;/i&gt;&#xA;    &lt;span class=&#34;sr-only&#34;&gt;链接到标题&lt;/span&gt;&#xA;  &lt;/a&gt;&#xA;&lt;/h2&gt;&#xA;&lt;p&gt;总结一下 Unity 烘焙的基本流程操作和相关基础概念&lt;/p&gt;</description>
    </item>
    <item>
      <title>Avpro插件的简单使用</title>
      <link>https://NonoNoe.github.io/posts/avpro%E6%8F%92%E4%BB%B6%E7%9A%84%E7%AE%80%E5%8D%95%E4%BD%BF%E7%94%A8/</link>
      <pubDate>Mon, 09 Feb 2026 17:44:08 +0800</pubDate>
      <guid>https://NonoNoe.github.io/posts/avpro%E6%8F%92%E4%BB%B6%E7%9A%84%E7%AE%80%E5%8D%95%E4%BD%BF%E7%94%A8/</guid>
      <description>&lt;div class=&#34;my-toc&#34;&gt;&#xD;&#xA;  &lt;h1&gt;目录&lt;/h1&gt;&#xD;&#xA;  &lt;nav id=&#34;TableOfContents&#34;&gt;&#xA;  &lt;ul&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#简介&#34;&gt;简介&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#1mediaplayer&#34;&gt;1，MediaPlayer&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#2-display-组件&#34;&gt;2, Display 组件&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#3常用接口&#34;&gt;3，常用接口&lt;/a&gt;&#xA;      &lt;ul&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#1mediaplayercontrol&#34;&gt;1，MediaPlayer.Control&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#2mediaplayerinfo&#34;&gt;2，MediaPlayer.Info&lt;/a&gt;&lt;/li&gt;&#xA;      &lt;/ul&gt;&#xA;    &lt;/li&gt;&#xA;  &lt;/ul&gt;&#xA;&lt;/nav&gt;&#xD;&#xA;&lt;/div&gt;&#xA;&lt;a href=&#34;#&#34; class=&#34;back-to-top&#34;&gt;↑ 返回顶部&lt;/a&gt;&#xD;&#xA;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;   &#xD;&#xA;  .back-to-top {&#xD;&#xA;    position: fixed;&#xD;&#xA;     &#xD;&#xA;    bottom: 20px;&#xD;&#xA;     &#xD;&#xA;    right: 80px;&#xD;&#xA;     &#xD;&#xA;    background-color: #3c3c3c;&#xD;&#xA;    color: #fff;&#xD;&#xA;    padding: 0.6rem 1rem;&#xD;&#xA;    border-radius: 5px;&#xD;&#xA;    text-decoration: none;&#xD;&#xA;    font-size: 1.2rem;&#xD;&#xA;    display: none;&#xD;&#xA;     &#xD;&#xA;    z-index: 1000;&#xD;&#xA;    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);&#xD;&#xA;    transition: opacity 0.3s ease;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;  .back-to-top:hover {&#xD;&#xA;    background-color: #b4b4b4;&#xD;&#xA;    color: rgb(255, 255, 255);&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;  .back-to-top.show {&#xD;&#xA;    display: block;&#xD;&#xA;  }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&#xD;&#xA;&lt;script&gt;&#xD;&#xA;  &#xD;&#xA;  const btn = document.querySelector(&#39;.back-to-top&#39;);&#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;  window.addEventListener(&#39;scroll&#39;, () =&gt; {&#xD;&#xA;    if (window.scrollY &gt; 200) { &#xD;&#xA;      btn.classList.add(&#39;show&#39;);&#xD;&#xA;    } else {&#xD;&#xA;      btn.classList.remove(&#39;show&#39;);&#xD;&#xA;    }&#xD;&#xA;  });&#xD;&#xA;&lt;/script&gt;&#xA;&lt;h2 id=&#34;简介&#34;&gt;&#xA;  简介&#xA;  &lt;a class=&#34;heading-link&#34; href=&#34;#%e7%ae%80%e4%bb%8b&#34;&gt;&#xA;    &lt;i class=&#34;fa-solid fa-link&#34; aria-hidden=&#34;true&#34; title=&#34;链接到标题&#34;&gt;&lt;/i&gt;&#xA;    &lt;span class=&#34;sr-only&#34;&gt;链接到标题&lt;/span&gt;&#xA;  &lt;/a&gt;&#xA;&lt;/h2&gt;&#xA;&lt;p&gt;Unity 的 Avpro 插件是用于视频播放的一个插件，简单好用！&lt;/p&gt;</description>
    </item>
    <item>
      <title>关于unity的UGUI——ui布局及自适应相关问题</title>
      <link>https://NonoNoe.github.io/posts/%E5%85%B3%E4%BA%8Eunity%E7%9A%84uigi%E5%B8%83%E5%B1%80%E4%B8%8E%E8%87%AA%E9%80%82%E5%BA%94%E7%9B%B8%E5%85%B3%E9%97%AE%E9%A2%98/</link>
      <pubDate>Fri, 06 Feb 2026 15:12:54 +0800</pubDate>
      <guid>https://NonoNoe.github.io/posts/%E5%85%B3%E4%BA%8Eunity%E7%9A%84uigi%E5%B8%83%E5%B1%80%E4%B8%8E%E8%87%AA%E9%80%82%E5%BA%94%E7%9B%B8%E5%85%B3%E9%97%AE%E9%A2%98/</guid>
      <description>&lt;div class=&#34;my-toc&#34;&gt;&#xD;&#xA;  &lt;h1&gt;目录&lt;/h1&gt;&#xD;&#xA;  &lt;nav id=&#34;TableOfContents&#34;&gt;&#xA;  &lt;ul&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#0简介&#34;&gt;0，简介&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#1canvas&#34;&gt;1，Canvas&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#2canvas-scaler-与-graphic-raycaster&#34;&gt;2，Canvas Scaler 与 Graphic Raycaster&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#3rect-transform&#34;&gt;3，Rect Transform&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#4万恶之源-layout-group-们&#34;&gt;4，万恶之源 Layout Group 们&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#5layout-element&#34;&gt;5，Layout Element&lt;/a&gt;&lt;/li&gt;&#xA;    &lt;li&gt;&lt;a href=&#34;#6比万恶之源还搞心态的-scrollview-组件&#34;&gt;6,比万恶之源还搞心态的 ScrollView 组件&lt;/a&gt;&lt;/li&gt;&#xA;  &lt;/ul&gt;&#xA;&lt;/nav&gt;&#xD;&#xA;&lt;/div&gt;&#xA;&lt;a href=&#34;#&#34; class=&#34;back-to-top&#34;&gt;↑ 返回顶部&lt;/a&gt;&#xD;&#xA;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;   &#xD;&#xA;  .back-to-top {&#xD;&#xA;    position: fixed;&#xD;&#xA;     &#xD;&#xA;    bottom: 20px;&#xD;&#xA;     &#xD;&#xA;    right: 80px;&#xD;&#xA;     &#xD;&#xA;    background-color: #3c3c3c;&#xD;&#xA;    color: #fff;&#xD;&#xA;    padding: 0.6rem 1rem;&#xD;&#xA;    border-radius: 5px;&#xD;&#xA;    text-decoration: none;&#xD;&#xA;    font-size: 1.2rem;&#xD;&#xA;    display: none;&#xD;&#xA;     &#xD;&#xA;    z-index: 1000;&#xD;&#xA;    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);&#xD;&#xA;    transition: opacity 0.3s ease;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;  .back-to-top:hover {&#xD;&#xA;    background-color: #b4b4b4;&#xD;&#xA;    color: rgb(255, 255, 255);&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;  .back-to-top.show {&#xD;&#xA;    display: block;&#xD;&#xA;  }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&#xD;&#xA;&lt;script&gt;&#xD;&#xA;  &#xD;&#xA;  const btn = document.querySelector(&#39;.back-to-top&#39;);&#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;  window.addEventListener(&#39;scroll&#39;, () =&gt; {&#xD;&#xA;    if (window.scrollY &gt; 200) { &#xD;&#xA;      btn.classList.add(&#39;show&#39;);&#xD;&#xA;    } else {&#xD;&#xA;      btn.classList.remove(&#39;show&#39;);&#xD;&#xA;    }&#xD;&#xA;  });&#xD;&#xA;&lt;/script&gt;&#xA;&lt;h2 id=&#34;0简介&#34;&gt;&#xA;  0，简介&#xA;  &lt;a class=&#34;heading-link&#34; href=&#34;#0%e7%ae%80%e4%bb%8b&#34;&gt;&#xA;    &lt;i class=&#34;fa-solid fa-link&#34; aria-hidden=&#34;true&#34; title=&#34;链接到标题&#34;&gt;&lt;/i&gt;&#xA;    &lt;span class=&#34;sr-only&#34;&gt;链接到标题&lt;/span&gt;&#xA;  &lt;/a&gt;&#xA;&lt;/h2&gt;&#xA;&lt;p&gt;之前被 Unity 的 UI 布局之类的整得特别崩溃，总之是想写一篇文章稍微总结一下学到的新东西和踩过的一堆坑，就直接从最基础的开始总结&lt;/p&gt;</description>
    </item>
    <item>
      <title>面向新手的Hugo文章信息添加方式</title>
      <link>https://NonoNoe.github.io/posts/hugo%E5%A2%9E%E5%8A%A0%E6%96%87%E7%AB%A0%E5%BC%80%E5%A4%B4%E6%A0%87%E7%AD%BE/</link>
      <pubDate>Fri, 11 Apr 2025 20:37:01 +0800</pubDate>
      <guid>https://NonoNoe.github.io/posts/hugo%E5%A2%9E%E5%8A%A0%E6%96%87%E7%AB%A0%E5%BC%80%E5%A4%B4%E6%A0%87%E7%AD%BE/</guid>
      <description>&lt;a href=&#34;#&#34; class=&#34;back-to-top&#34;&gt;↑ 返回顶部&lt;/a&gt;&#xD;&#xA;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;   &#xD;&#xA;  .back-to-top {&#xD;&#xA;    position: fixed;&#xD;&#xA;     &#xD;&#xA;    bottom: 20px;&#xD;&#xA;     &#xD;&#xA;    right: 80px;&#xD;&#xA;     &#xD;&#xA;    background-color: #3c3c3c;&#xD;&#xA;    color: #fff;&#xD;&#xA;    padding: 0.6rem 1rem;&#xD;&#xA;    border-radius: 5px;&#xD;&#xA;    text-decoration: none;&#xD;&#xA;    font-size: 1.2rem;&#xD;&#xA;    display: none;&#xD;&#xA;     &#xD;&#xA;    z-index: 1000;&#xD;&#xA;    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);&#xD;&#xA;    transition: opacity 0.3s ease;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;  .back-to-top:hover {&#xD;&#xA;    background-color: #b4b4b4;&#xD;&#xA;    color: rgb(255, 255, 255);&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;  .back-to-top.show {&#xD;&#xA;    display: block;&#xD;&#xA;  }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&#xD;&#xA;&lt;script&gt;&#xD;&#xA;  &#xD;&#xA;  const btn = document.querySelector(&#39;.back-to-top&#39;);&#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;  window.addEventListener(&#39;scroll&#39;, () =&gt; {&#xD;&#xA;    if (window.scrollY &gt; 200) { &#xD;&#xA;      btn.classList.add(&#39;show&#39;);&#xD;&#xA;    } else {&#xD;&#xA;      btn.classList.remove(&#39;show&#39;);&#xD;&#xA;    }&#xD;&#xA;  });&#xD;&#xA;&lt;/script&gt;&#xA;&lt;p&gt;本文中所使用的 hugo 主题中，series 是默认不在文章开头显示的，那么如何修改才能使 series 的参数和 author/categories/tags 等参数保持相同格式显示在文章内呢？&lt;/p&gt;</description>
    </item>
    <item>
